# AI Assistant uses completely free and unlimited open-source models
# No API keys required - everything is built-in and free
# Supports both online (Hugging Face) and local (Ollama) models

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB connection string (leave empty to use in-memory DB)
MONGODB_URI=

# Secret for JWT token signing
JWT_SECRET=

# Secure seed password for the default admin user
ADMIN_SEED_PASSWORD=
